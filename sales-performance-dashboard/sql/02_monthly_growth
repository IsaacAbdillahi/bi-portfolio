/*
Purpose:
- Calculate month-over-month (MoM) sales growth
- Enable trend monitoring and performance comparison over time
- Support time-based KPIs and insights in Power BI

Design Notes:
- Sales are analysed at a monthly granularity to support trend analysis
- Growth is calculated independently for each product and region
- Window functions are used to compare each month to its previous period

Output:
- One row per product, region, and month
- Monthly total sales values
- Month-over-month sales growth
*/

WITH base_sales AS (
    SELECT
        order_date,
        product,
        region,
        sales_amount
    FROM sales
),

monthly_sales AS (
    SELECT
        DATE_TRUNC('month', order_date) AS sales_month,
        product,
        region,
        SUM(sales_amount) AS total_sales
    FROM base_sales
    GROUP BY
        DATE_TRUNC('month', order_date),
        product,
        region
),

monthly_growth AS (
    SELECT
        sales_month,
        product,
        region,
        total_sales,
        total_sales
            - LAG(total_sales) OVER (
                PARTITION BY product, region
                ORDER BY sales_month
            ) AS mom_growth
    FROM monthly_sales
)

SELECT
    sales_month,
    product,
    region,
    total_sales,
    mom_growth
FROM monthly_growth
ORDER BY sales_month;

-- This dataset is used directly in:
-- Sales Performance dashboards to track month-over-month growth
``
