-- Base sales layer
-- Defines the core dataset used for time-based analysis
-- Selecting only required fields keeps downstream logic clear and consistent
WITH base_sales AS (
    SELECT
        order_date,
        product,
        region,
        sales_amount
    FROM sales
),

-- Monthly aggregation layer
-- Aggregates transactional sales data to a monthly level
-- This granularity supports trend analysis and growth calculations
monthly_sales AS (
    SELECT
        DATE_TRUNC('month', order_date) AS sales_month,
        product,
        region,
        SUM(sales_amount) AS total_sales
    FROM base_sales
    GROUP BY
        DATE_TRUNC('month', order_date),
        product,
        region
),

-- Month-over-Month growth calculation
-- Compares each month's total sales to the previous month
-- Partitioning by product and region allows independent trend analysis
monthly_growth AS (
    SELECT
        sales_month,
        product,
        region,
        total_sales,
        total_sales
            - LAG(total_sales) OVER (
                PARTITION BY product, region
                ORDER BY sales_month
            ) AS mom_growth
    FROM monthly_sales
)

-- Final reporting output
-- This dataset can be consumed directly by BI tools
-- and supports visualisation of monthly growth trends
SELECT
    sales_month,
    product,
    region,
    total_sales,
    mom_growth
FROM monthly_growth
ORDER BY sales_month;
