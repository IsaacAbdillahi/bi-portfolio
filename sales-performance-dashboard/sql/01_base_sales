-- Base sales layer
-- This CTE defines the core dataset used throughout the analysis
-- Only essential fields are selected to ensure consistency
WITH base_sales AS (
    SELECT
        order_date,
        product,
        region,
        sales_amount
    FROM sales
),

-- Monthly aggregation layer
-- Sales are aggregated at a monthly level to support time-based analysis
-- such as trend monitoring and growth calculations
monthly_sales AS (
    SELECT
        DATE_TRUNC('month', order_date) AS sales_month,
        product,
        region,
        SUM(sales_amount) AS total_sales
    FROM base_sales
    GROUP BY
        DATE_TRUNC('month', order_date),
        product,
        region
)

-- Final output
-- This dataset is reporting-ready and can be consumed directly
-- by BI tools such as Power BI
SELECT
    sales_month,
    product,
    region,
    total_sales
FROM monthly_sales
ORDER BY sales_month;
