WITH base_sales AS (
    SELECT
        order_date,
        product,
        region,
        sales_amount
    FROM sales
),

monthly_sales AS (
    SELECT
        DATE_TRUNC('month', order_date) AS sales_month,
        product,
        region,
        SUM(sales_amount) AS total_sales
    FROM base_sales
    GROUP BY
        DATE_TRUNC('month', order_date),
        product,
        region
)

SELECT
    sales_month,
    product,
    region,
    total_sales
FROM monthly_sales
ORDER BY sales_month;

