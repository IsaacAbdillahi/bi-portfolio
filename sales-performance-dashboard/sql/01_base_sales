/*
Purpose:
- Create a clean, consistent base sales dataset for analysis
- Aggregate transactional sales data to a monthly level
- Provide a reporting-ready dataset for time-based performance analysis

Design Notes:
- Only essential fields are selected to ensure consistency across analysis
- Sales are aggregated monthly to support trend analysis and growth calculations
- This dataset is designed to be consumed directly by BI tools such as Power BI

Output:
- One row per product, region, and month
- Monthly total sales values
*/

WITH base_sales AS (
    SELECT
        order_date,
        product,
        region,
        sales_amount
    FROM sales
),

monthly_sales AS (
    SELECT
        DATE_TRUNC('month', order_date) AS sales_month,
        product,
        region,
        SUM(sales_amount) AS total_sales
    FROM base_sales
    GROUP BY
        DATE_TRUNC('month', order_date),
        product,
        region
)

SELECT
    sales_month,
    product,
    region,
    total_sales
FROM monthly_sales
ORDER BY sales_month;

-- This dataset is used as the core input for:
-- Sales Performance dashboards and time-based analysis in Power BI
